# Growmerce MVP Vertical Slice V1 — environment example
# Copy to `.env.local` and fill in. Vite only exposes vars prefixed with VITE_.

# WhatsApp number for the handoff deep link.
# Format: country code + number, DIGITS ONLY — no leading +, no spaces, no dashes, no leading 00.
#   e.g. Saudi  9665XXXXXXXX   ·   UAE  9715XXXXXXXX   ·   Egypt  201XXXXXXXXX
# If unset, the app runs in demo mode: the WhatsApp link opens the contact picker and a
# "demo mode" note is shown. NO secrets here — this is a public deep-link number.
VITE_GROWMERCE_WHATSAPP_NUMBER=

# Lead sink — HTTPS endpoint that receives submitted leads (JSON POST).
# Can be a form service (Formspree / Web3Forms / Basin / Formspark), a serverless function
# (Netlify / Vercel / Cloudflare), a Google Apps Script web app, or a Supabase REST insert URL.
# Must accept a JSON body and CORS from the deployed origin. If unset, lead capture falls back
# to localStorage-only (clearly flagged in the UI). NOT a CRM, no marketplace data is fetched.
#   e.g. https://formspree.io/f/xxxxxxx   or   https://script.google.com/macros/s/AKfyc.../exec
VITE_GROWMERCE_LEAD_ENDPOINT=

# --- Real Intelligence System (upcoming phases — NOT wired into the UI yet) ---
# These exist for the Supabase backend foundation (schema only in Phase 1 Sprint 1).
# The current MVP works fully WITHOUT them. The anon key is a public, RLS-guarded
# client key — still, do NOT commit real values; set them in .env.local / host env.
# NEVER put the Supabase service_role key in a VITE_ var or the client bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Master feature flag for the real (evidence-backed) intelligence path. Keep false
# until the real report engine + human review are live; false = current demo behavior.
VITE_REAL_INTELLIGENCE=false

# --- Edge Function secrets (SERVER-SIDE ONLY — never in the frontend bundle) ---
# These are NOT VITE_ vars and are NOT read by the client. Do NOT set real values
# in .env.local. Configure them in Supabase as function secrets, e.g.:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...  GROWMERCE_ALLOWED_ORIGINS=https://your-app.vercel.app
# SUPABASE_URL is injected into Edge Functions automatically.
# SUPABASE_SERVICE_ROLE_KEY — full-access key; exposing it client-side would bypass RLS. Keep secret.
# GROWMERCE_ALLOWED_ORIGINS — comma-separated origins allowed to call the function (empty = reflect any, demo only).
SUPABASE_SERVICE_ROLE_KEY=
GROWMERCE_ALLOWED_ORIGINS=
