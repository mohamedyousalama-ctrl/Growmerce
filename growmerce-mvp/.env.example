# Growmerce MVP Vertical Slice V1 — environment example
# Copy to `.env.local` and fill in. Vite only exposes vars prefixed with VITE_.

# WhatsApp number for the handoff deep link.
# Format: country code + number, DIGITS ONLY — no leading +, no spaces, no dashes, no leading 00.
#   e.g. Saudi  9665XXXXXXXX   ·   UAE  9715XXXXXXXX   ·   Egypt  201XXXXXXXXX
# If unset, the app runs in demo mode: the WhatsApp link opens the contact picker and a
# "demo mode" note is shown. NO secrets here — this is a public deep-link number.
VITE_GROWMERCE_WHATSAPP_NUMBER=

# Lead sink — HTTPS endpoint that receives submitted leads (JSON POST).
# Can be a form service (Formspree / Web3Forms / Basin / Formspark), a serverless function
# (Netlify / Vercel / Cloudflare), a Google Apps Script web app, or a Supabase REST insert URL.
# Must accept a JSON body and CORS from the deployed origin. If unset, lead capture falls back
# to localStorage-only (clearly flagged in the UI). NOT a CRM, no marketplace data is fetched.
#   e.g. https://formspree.io/f/xxxxxxx   or   https://script.google.com/macros/s/AKfyc.../exec
VITE_GROWMERCE_LEAD_ENDPOINT=
